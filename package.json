  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:local": "NODE_ENV=development next dev -p 3000",
    "build": "next build --webpack",
    "start": "next start -p 3000",
    "lint": "next lint",
    "dev:clean": "rm -rf .next && next dev -p 3000",
    "storybook": "storybook dev -p 6006",
    "clean:install": "rm -rf node_modules package-lock.json && npm install",
    "clean:all": "rm -rf node_modules package-lock.json .next && npm install",
    "fresh": "npm cache clean --force && rm -rf node_modules package-lock.json .next && npm install"
  },
