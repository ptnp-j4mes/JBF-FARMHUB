    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.577.0",
    "next": "16.1.1",
    "notistack": "^3.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
